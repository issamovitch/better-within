# SQLite path is resolved relative to prisma/schema.prisma, NOT the process's
# working directory — always use a relative path here. An absolute path (e.g.
# copied from a local dev machine) will break as soon as the app runs on a
# different machine/container, causing Prisma error 14 "Unable to open the
# database file".
DATABASE_URL="file:./db/custom.db"

# Resend email delivery (book PDF + audio links)
RESEND_API_KEY=
EMAIL_FROM=
PDF_URL=
AUDIO_URL=
